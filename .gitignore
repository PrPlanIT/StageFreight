.stagefreight/*
!.stagefreight/badges/
src/output/banner_art_gen.go

# compiled binaries — never commit these
/cli
/stagefreight
/stagefreight-bin
*.exe

# binary build output (.stagefreight/dist/<os>-<arch>/ binaries, archives,
# SHA256SUMS) is already covered by the .stagefreight/* rule above. The bare
# /dist/ guard remains for legacy/`--output-dir dist` local builds.
/dist/
